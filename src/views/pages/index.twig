{#
| Variable         | Type       | Description                                                         |
|------------------|------------|---------------------------------------------------------------------|
| page             | object     |                                                                     |
| page.title       | string     | *could be html                                                      |
| page.slug        | string     | ex: "cat.show"                                                      |
#}
{% extends "layouts.master" %}
{% block content %}
    {# Hero Banner with Vehicle Filter #}
    <section class="hero-section">
        <div class="hero-slider">
            <div class="hero-slide active">
                <div class="hero-image">
                    <img src="{{ 'images/slider.png'|asset }}" alt="Hero Banner" onerror="this.src='{{ 'images/placeholder.png'|asset }}'">
                </div>
                <div class="hero-content">
                    <div class="hero-text">
                        <h2>مشغلات البطاريات</h2>
                        <p>شغّل البطاريات في ثوانٍ</p>
                        <button class="shop-now-btn">تسوق الآن <i class="fas fa-arrow-right"></i></button>
                    </div>
                </div>
                <div class="price-badge">من 49.99 دولار</div>
            </div>
        </div>
        
        {# Vehicle Filter - Fixed in Hero Banner #}
        <div class="hero-vehicle-filter">
            <div class="vehicle-filter-form">
                <h5>اختر سيارتك</h5>
                <div class="vehicle-filter-fields">
                    <select class="vehicle-select">
                        <option>العلامة التجارية</option>
                    </select>
                    <select class="vehicle-select">
                        <option>الموديل</option>
                    </select>
                    <select class="vehicle-select">
                        <option>السنة</option>
                    </select>
                    <select class="vehicle-select">
                        <option>المحرك</option>
                    </select>
                    <select class="vehicle-select">
                        <option>الفئة</option>
                    </select>
                    <button class="vehicle-search-btn">بحث</button>
                </div>
                <div class="vehicle-filter-or">
                    <span>أو</span>
                </div>
                <div class="vehicle-filter-vin">
                    <input type="text" class="vin-input" placeholder="البحث برقم الشاصي">
                    <button class="vin-search-btn">بحث</button>
                </div>
            </div>
        </div>
        
        <div class="slider-dots">
            <span class="dot active"></span>
            <span class="dot"></span>
            <span class="dot"></span>
        </div>
    </section>
    
    {# Promotional Banners - Top Brands #}
    <section class="promo-banners">
        <div class="container">
            <div class="banner-grid">
                <div class="promo-banner batteries-banner">
                    <div class="banner-content">
                        <span class="banner-badge">أفضل العلامات التجارية</span>
                        <h2>البطاريات</h2>
                        <p>ابق مشحوناً!</p>
                        <button class="banner-btn">تسوق الآن <i class="fas fa-arrow-right"></i></button>
                    </div>
                    <div class="banner-image">
                        <img src="{{ 'images/battery.png'|asset }}" alt="البطاريات" onerror="this.src='{{ 'images/placeholder.png'|asset }}'">
                    </div>
                </div>
                <div class="promo-banner tires-banner">
                    <div class="banner-content">
                        <span class="banner-badge green">اشتري 3 واحصل على 1 مجاناً</span>
                        <h2>الإطارات والعجلات</h2>
                        <p>ابق آمناً على الطريق!</p>
                        <button class="banner-btn">تسوق الآن <i class="fas fa-arrow-right"></i></button>
                    </div>
                    <div class="banner-image">
                        <img src="https://enovathemes.com/mobex/wp-content/uploads/banner7-img.webp" alt="الإطارات">
                    </div>
                </div>
                <div class="promo-banner springs-banner">
                    <div class="banner-content">
                        <span class="banner-badge yellow">تخفيضات كبيرة</span>
                        <h2>اشتري 1 واحصل على 1</h2>
                        <p>مجاناً</p>
                        <button class="banner-btn">تسوق الآن <i class="fas fa-arrow-right"></i></button>
                    </div>
                    <div class="banner-image">
                        <img src="https://enovathemes.com/mobex/wp-content/uploads/banner8-img.webp" alt="الزنبركات">
                    </div>
                </div>
            </div>
        </div>
    </section>
    
    {# Featured Categories Section - Directly Added #}
    <section class="s-block s-block--categories" style="display: block !important; visibility: visible !important; opacity: 1 !important; margin-top: 2rem !important; margin-bottom: 2rem !important;">
        <div class="container" style="display: block !important; visibility: visible !important; width: 100% !important;">
            <div class="s-block__title" style="display: block !important; visibility: visible !important;">
                <div class="right-side">
                    <h2 style="display: block !important; visibility: visible !important;">فئات مميزة</h2>
                </div>
            </div>
            <salla-slider type="carousel" controls-outer show-controls="true" id="featured-categories-slider" style="display: block !important; visibility: visible !important; width: 100% !important;">
                <div slot="items" id="categories-slider-items" style="display: flex !important; visibility: visible !important;">
                    {# Categories will be loaded here #}
                </div>
            </salla-slider>
        </div>
    </section>
    
    {% component home %}
    
    {# Deals of the Week Section #}
    <section class="deals-section">
        <div class="container">
            <div class="deals-header">
                <h2>عروض الأسبوع!</h2>
                <div class="deals-countdown">
                    <span class="timer-box">09</span>
                    <span class="timer-separator">:</span>
                    <span class="timer-box">20</span>
                    <span class="timer-separator">:</span>
                    <span class="timer-box">54</span>
                    <span class="timer-separator">:</span>
                    <span class="timer-box">27</span>
                </div>
                <div class="deals-nav">
                    <button class="nav-arrow deals-prev" aria-label="Previous">
                        <i class="fas fa-chevron-left"></i>
                    </button>
                    <button class="nav-arrow deals-next" aria-label="Next">
                        <i class="fas fa-chevron-right"></i>
                    </button>
                </div>
            </div>
            
            <div class="deals-products-wrapper">
                <salla-products-list source="latest" limit="12"></salla-products-list>
            </div>
        </div>
    </section>
{% endblock %}
{% block scripts %}
    <script defer src="{{ 'home.js' | asset }}"></script>
    <script>
        // Load categories directly when page loads
        (function() {
            function loadCategories() {
                const container = document.getElementById('categories-slider-items');
                if (!container) {
                    setTimeout(loadCategories, 100);
                    return;
                }

                // Use Salla API to get categories
                if (typeof salla !== 'undefined' && salla.api) {
                    salla.api.get('/categories', { limit: 12 })
                        .then(response => {
                            if (response && response.data && response.data.data && response.data.data.length > 0) {
                                let html = '';
                                response.data.data.forEach(function(category) {
                                    const img = category.image || '{{ "images/placeholder.png" | asset }}';
                                    const url = category.url || '#';
                                    const name = category.name || '';
                                    html += '<div class="swiper-slide slide--one-sixth" style="display: block !important; visibility: visible !important;"><a href="' + url + '" class="slide--cat-entry" style="display: flex !important; visibility: visible !important;"><img src="' + img + '" class="w-16 h-16 object-cover rounded-full mb-2.5" width="64" height="64" alt="' + name + '" style="display: block !important; visibility: visible !important; width: 64px !important; height: 64px !important;"/><h2 style="display: block !important; visibility: visible !important;">' + name + '</h2></a></div>';
                                });
                                container.innerHTML = html;
                                
                                // Update slider
                                const slider = document.getElementById('featured-categories-slider');
                                if (slider && slider.update) {
                                    setTimeout(function() { slider.update(); }, 200);
                                }
                            }
                        })
                        .catch(function(err) {
                            console.log('Categories loading...', err);
                        });
                } else {
                    setTimeout(loadCategories, 200);
                }
            }
            
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', loadCategories);
            } else {
                loadCategories();
            }
            
            // Also try when Salla is ready
            if (typeof salla !== 'undefined') {
                salla.onReady().then(loadCategories);
            }
        })();
    </script>
{% endblock %}