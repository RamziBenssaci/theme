{#
| Variable         | Type       | Description                                                         |
|------------------|------------|---------------------------------------------------------------------|
| page             | object     |                                                                     |
| page.title       | string     | *could be html                                                      |
| page.slug        | string     | ex: "cat.show"                                                      |
#}
{% extends "layouts.master" %}
{% block content %}
    {# Hero Banner with Vehicle Filter #}
    <section class="hero-section">
        <div class="hero-slider">
            <div class="hero-slide active">
                <div class="hero-image">
                    <img src="{{ 'images/slider.png'|asset }}" alt="Hero Banner" onerror="this.src='{{ 'images/placeholder.png'|asset }}'">
                </div>
                <div class="hero-content">
                    <div class="hero-text">
                        <h2>JUMP STARTERS</h2>
                        <p>START BATTERIES IN SECONDS</p>
                        <button class="shop-now-btn">Shop now <i class="fas fa-arrow-right"></i></button>
                    </div>
                </div>
                <div class="price-badge">FROM $49.99</div>
            </div>
        </div>
        
        {# Vehicle Filter - Fixed in Hero Banner #}
        <div class="hero-vehicle-filter">
            <div class="vehicle-filter-form">
                <h5>Select your car</h5>
                <div class="vehicle-filter-fields">
                    <select class="vehicle-select">
                        <option>Make</option>
                    </select>
                    <select class="vehicle-select">
                        <option>Model</option>
                    </select>
                    <select class="vehicle-select">
                        <option>Year</option>
                    </select>
                    <select class="vehicle-select">
                        <option>Engine</option>
                    </select>
                    <select class="vehicle-select">
                        <option>Trim</option>
                    </select>
                    <button class="vehicle-search-btn">Search</button>
                </div>
                <div class="vehicle-filter-or">
                    <span>OR</span>
                </div>
                <div class="vehicle-filter-vin">
                    <input type="text" class="vin-input" placeholder="Search by VIN">
                    <button class="vin-search-btn">Search</button>
                </div>
            </div>
        </div>
        
        <div class="slider-dots">
            <span class="dot active"></span>
            <span class="dot"></span>
            <span class="dot"></span>
        </div>
    </section>
    
    {# Promotional Banners - Top Brands #}
    <section class="promo-banners">
        <div class="container">
            <div class="banner-grid">
                <div class="promo-banner batteries-banner">
                    <div class="banner-content">
                        <span class="banner-badge">Top brands</span>
                        <h2>BATTERIES</h2>
                        <p>Stay charged up!</p>
                        <button class="banner-btn">Shop now <i class="fas fa-arrow-right"></i></button>
                    </div>
                    <div class="banner-image">
                        <img src="{{ 'images/battery.png'|asset }}" alt="Battery" onerror="this.src='https://enovathemes.com/mobex/wp-content/uploads/banner8-img.webp'">
                    </div>
                </div>
                <div class="promo-banner tires-banner">
                    <div class="banner-content">
                        <span class="banner-badge green">Buy 3 Get 1 For Free</span>
                        <h2>TIRES & WHEELS</h2>
                        <p>Stay safe on road!</p>
                        <button class="banner-btn">Shop now <i class="fas fa-arrow-right"></i></button>
                    </div>
                    <div class="banner-image">
                        <img src="https://enovathemes.com/mobex/wp-content/uploads/banner7-img.webp" alt="Tires">
                    </div>
                </div>
                <div class="promo-banner springs-banner">
                    <div class="banner-content">
                        <span class="banner-badge yellow">Big sale</span>
                        <h2>BUY 1 GET 1</h2>
                        <p>FREE</p>
                        <button class="banner-btn">Shop now <i class="fas fa-arrow-right"></i></button>
                    </div>
                    <div class="banner-image">
                        <img src="https://enovathemes.com/mobex/wp-content/uploads/banner8-img.webp" alt="Springs">
                    </div>
                </div>
            </div>
        </div>
    </section>
    
    {# Deals of the Week Section #}
    {% include "components/home/deals-of-week.twig" %}
    
    {% component home %}
{% endblock %}
{% block scripts %}
    <script defer src="{{ 'home.js' | asset }}"></script>
{% endblock %}