{#
| Variable         | Type       | Description                                                         |
|------------------|------------|---------------------------------------------------------------------|
| page             | object     |                                                                     |
| page.title       | string     | *could be html                                                      |
| page.slug        | string     | ex: "cat.show"                                                      |
#}
{% extends "layouts.master" %}
{% block content %}
    {# Hero Banner with Vehicle Filter #}
    <section class="hero-section">
        <div class="hero-slider">
            <div class="hero-slide active">
                <div class="hero-image">
                    <img src="{{ 'images/slider.png'|asset }}" alt="Hero Banner" onerror="this.src='{{ 'images/placeholder.png'|asset }}'">
                </div>
                <div class="hero-content">
                    <div class="hero-text">
                        <h2>{{ trans('blocks.hero.battery_starters') }}</h2>
                        <p>{{ trans('blocks.hero.start_batteries_seconds') }}</p>
                        <button class="shop-now-btn">{{ trans('blocks.hero.shop_now') }} <i class="fas fa-arrow-right"></i></button>
                    </div>
                </div>
                <div class="price-badge">{{ trans('blocks.hero.from_price') }}</div>
            </div>
        </div>
        
        {# Vehicle Filter - Fixed in Hero Banner #}
        <div class="hero-vehicle-filter">
            <div class="vehicle-filter-form">
                <h5>{{ trans('blocks.hero.choose_car') }}</h5>
                <div class="vehicle-filter-fields">
                    <select class="vehicle-select">
                        <option>{{ trans('blocks.hero.brand') }}</option>
                    </select>
                    <select class="vehicle-select">
                        <option>{{ trans('blocks.hero.model') }}</option>
                    </select>
                    <select class="vehicle-select">
                        <option>{{ trans('blocks.hero.year') }}</option>
                    </select>
                    <select class="vehicle-select">
                        <option>{{ trans('blocks.hero.engine') }}</option>
                    </select>
                    <select class="vehicle-select">
                        <option>{{ trans('blocks.hero.trim') }}</option>
                    </select>
                    <button class="vehicle-search-btn">{{ trans('blocks.hero.search') }}</button>
                </div>
                <div class="vehicle-filter-or">
                    <span>{{ trans('blocks.hero.or') }}</span>
                </div>
                <div class="vehicle-filter-vin">
                    <input type="text" class="vin-input" placeholder="{{ trans('blocks.hero.search_by_vin') }}">
                    <button class="vin-search-btn">{{ trans('blocks.hero.search') }}</button>
                </div>
            </div>
        </div>
        
        <div class="slider-dots">
            <span class="dot active"></span>
            <span class="dot"></span>
            <span class="dot"></span>
        </div>
    </section>
    
    {# Promotional Banners - Top Brands #}
    <section class="promo-banners">
        <div class="container">
            <div class="banner-grid">
                <div class="promo-banner batteries-banner">
                    <div class="banner-content">
                        <span class="banner-badge">{{ trans('blocks.banners.top_brands') }}</span>
                        <h2>{{ trans('blocks.banners.batteries') }}</h2>
                        <p>{{ trans('blocks.banners.stay_charged') }}</p>
                        <button class="banner-btn">{{ trans('blocks.hero.shop_now') }} <i class="fas fa-arrow-right"></i></button>
                    </div>
                    <div class="banner-image">
                        <img src="{{ 'images/battery.png'|asset }}" alt="{{ trans('blocks.banners.batteries') }}" onerror="this.src='{{ 'images/placeholder.png'|asset }}'">
                    </div>
                </div>
                <div class="promo-banner tires-banner">
                    <div class="banner-content">
                        <span class="banner-badge green">{{ trans('blocks.banners.buy_3_get_1') }}</span>
                        <h2>{{ trans('blocks.banners.tires_wheels') }}</h2>
                        <p>{{ trans('blocks.banners.stay_safe') }}</p>
                        <button class="banner-btn">{{ trans('blocks.hero.shop_now') }} <i class="fas fa-arrow-right"></i></button>
                    </div>
                    <div class="banner-image">
                        <img src="https://enovathemes.com/mobex/wp-content/uploads/banner7-img.webp" alt="{{ trans('blocks.banners.tires_wheels') }}">
                    </div>
                </div>
                <div class="promo-banner springs-banner">
                    <div class="banner-content">
                        <span class="banner-badge yellow">{{ trans('blocks.banners.big_sales') }}</span>
                        <h2>{{ trans('blocks.banners.buy_1_get_1') }}</h2>
                        <p>{{ trans('blocks.banners.free') }}</p>
                        <button class="banner-btn">{{ trans('blocks.hero.shop_now') }} <i class="fas fa-arrow-right"></i></button>
                    </div>
                    <div class="banner-image">
                        <img src="https://enovathemes.com/mobex/wp-content/uploads/banner8-img.webp" alt="{{ trans('blocks.banners.springs') }}">
                    </div>
                </div>
            </div>
        </div>
    </section>
    
    {# Featured Categories Section #}
    <section class="featured-categories">
        <div class="container">
            <h4 class="section-title">{{ trans('blocks.home.featured_categories') }}</h4>
            <featured-categories>
                <div class="categories-grid">
                    {# Categories will be populated by JavaScript #}
                </div>
            </featured-categories>
        </div>
    </section>
    
    {% component home %}
    
    {# Deals of the Week Section #}
    <section class="deals-section">
        <div class="container">
            <div class="deals-header">
                <h2>{{ trans('blocks.home.deals_of_week') }}</h2>
                <div class="deals-countdown">
                    <span class="timer-box">09</span>
                    <span class="timer-separator">:</span>
                    <span class="timer-box">20</span>
                    <span class="timer-separator">:</span>
                    <span class="timer-box">54</span>
                    <span class="timer-separator">:</span>
                    <span class="timer-box">27</span>
                </div>
                <div class="deals-nav">
                    <button class="nav-arrow deals-prev" aria-label="Previous">
                        <i class="fas fa-chevron-left"></i>
                    </button>
                    <button class="nav-arrow deals-next" aria-label="Next">
                        <i class="fas fa-chevron-right"></i>
                    </button>
                </div>
            </div>
            
            <div class="deals-products-wrapper">
                <salla-products-list source="latest" limit="12"></salla-products-list>
            </div>
        </div>
    </section>
{% endblock %}
{% block scripts %}
    <script defer src="{{ 'home.js' | asset }}"></script>
    <script defer src="{{ 'featured-categories.js' | asset }}"></script>
{% endblock %}
{% endblock %}