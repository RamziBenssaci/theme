{#
| Variable         | Type    | Description                     |
|------------------|---------|---------------------------------|
| cart             | object  |                                 |
| cart.items_count | int     |                                 |
| cart.total       | string  | Formatted total ex: "١٠٠ ر.س"   |
#}
{% set important_links = theme.settings.get('important_links') %}
<header class="store-header">
  {# Top Nav - Contact Info Only #}
  <div class="top-navbar">
    <div class="container flex justify-between">
      <div class="flex-1 flex items-center gap-2">
          {# Footer Menu #}
          {% if important_links %}
            <salla-menu source="footer" topnav></salla-menu>
          {% endif %}
      </div>

      <salla-contacts is-header></salla-contacts>
    </div>
  </div>

  {# Main Nav - Row 1: Logo | Search | Currency/Language/Login/Cart #}
  <div id="mainnav" class="main-nav-container shadow-default bg-white flex items-center">
      <div class="inner bg-inherit w-full">
          <div class="container">
              {# Row 1 #}
              <div class="flex items-stretch justify-between relative main-nav-row-1">
                  {# Logo - Left #}
                  <div class="flex items-center">
                      <a class="lg:hidden mburger mburger--collapse leading-none rtl:ml-4 ltr:mr-4" href="#mobile-menu" aria-label="Open-menu">
                        <i class="sicon-menu text-primary text-2xl"></i>
                      </a>
                      <a class="navbar-brand" href="{{ store.url }}">
                          <img fetchpriority="high" width="100%" height="100%" loading="eager" src="{{ store.logo|cdn(175) }}" alt="{{ store.name }} logo">
                          {% if is_page('index') %}
                            <h1 class="sr-only">{{ store.name }}</h1>
                          {% else %}
                            <h2 class="sr-only">{{ store.name }}</h2>
                          {% endif %}
                      </a>
                  </div>
                  
                  {# Search bar - Center with category dropdown #}
                  <div class="header-search flex-1" style="max-width: 600px; margin: 0 20px;">
                    <div class="search-wrapper">
                      <select class="search-category">
                        <option>Select category</option>
                      </select>
                      <salla-search inline height="48"></salla-search>
                    </div>
                  </div>
                  
                  {# Currency/Language/Login/Cart - Right #}
                  <div class="flex items-center justify-end gap-3 my-2.5">
                      {# Currency & Language #}
                      <div class="header-buttons">
                          {% if store.settings.is_multilingual or store.settings.currencies_enabled %}
                              <button type="button" onclick="salla.event.dispatch('localization::open')" class="btn--rounded-gray basis-0">
                                  <span>{{ user.language.name }}</span>
                                  <span class="mx-1.5">|</span> <span>{{ currency.symbol }}</span>
                              </button>
                              <salla-localization-modal></salla-localization-modal>
                          {% endif %}
                      </div>
                      
                      {# Scopes | Branches #}
                      {% if store.scope %}
                          <button class="btn--rounded-gray"
                                  onclick="salla.event.dispatch('scopes::open', {'mode': 'default'})">
                              <i class="sicon-location rtl:ml-1 ltr:mr-1"></i> {{ store.scope.name }}
                          </button>
                      {% endif %}
                      
                      {# Login/User Menu #}
                      {% if user.type=='user' %}
                        <salla-user-menu avatar-only show-header></salla-user-menu>
                      {% else %}
                          <button class="header-btn login-btn" aria-label="Login" onclick="salla.event.dispatch('login::open')">
                            <i class="sicon-user-circle"></i>
                            <span>Login</span>
                          </button>
                      {% endif %}
                      
                      {# Cart #}
                      <salla-cart-summary class="ml-4 rtl:ml-[unset] rtl:mr-4">
                        <i slot="icon" class="header-btn__icon icon sicon-shopping-bag"></i>
                      </salla-cart-summary>
                  </div>
              </div>
              
          </div>
      </div>
  </div>
  
  {# Navigation Row 2: Nav Links | All Categories Button #}
  <nav class="main-nav-row-2">
      <div class="container">
          <div class="flex items-center justify-between">
              {# All Categories Button - Left #}
              <a href="#mobile-menu" class="all-categories-btn mburger mburger--collapse" aria-label="All Categories">
                  <i class="sicon-menu rtl:ml-2 ltr:mr-2"></i>
                  <span>All Categories</span>
                  <i class="sicon-sar rtl:mr-2 ltr:ml-2"></i>
              </a>
              
              {# Navigation Menu - Center #}
              <div class="flex-1 flex justify-center">
                  <custom-main-menu></custom-main-menu>
              </div>
              
              {# Empty space for alignment #}
              <div style="width: 150px;"></div>
          </div>
      </div>
  </nav>
</header>
