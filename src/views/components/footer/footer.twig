{# Footer Features Section - Above Footer #}
<section class="footer-features-section">
    <div class="container">
        <div class="footer-features">
            <div class="footer-feature">
                <i class="fas fa-headset"></i>
                <h3>خدمة خبيرة</h3>
                <p>فريقنا الودود متاح على مدار الأسبوع.</p>
            </div>
            <div class="footer-feature">
                <i class="fas fa-hand-holding-usd"></i>
                <h3>قيمة مذهلة</h3>
                <p>العلامات التجارية التي تفضلها، بأسعار تناسبك.</p>
            </div>
            <div class="footer-feature">
                <i class="fas fa-truck"></i>
                <h3>شحن سريع ومجاني</h3>
                <p>الشحن يتم بسرعة، والتوصيل خلال 1-3 أيام.</p>
            </div>
            <div class="footer-feature">
                <i class="fas fa-box"></i>
                <h3>اختيار لا يُقاوم</h3>
                <p>كل ما تريده لسيارتك، في مكان واحد.</p>
            </div>
        </div>
    </div>
</section>

<footer class="store-footer">
	<div aria-label="footer" class="store-footer__inner">
		<div class="container footer-content-grid">
			<div class="lg:col-span-2 rtl:lg:pl-20 ltr:lg:pr-20">
				<div class="footer-logo">
					<a href="{{ link('/') }}" class="flex items-center m-0">
						<h2>{{store.name}}</h2>
					</a>
					{% if store.description %}
						<p class="footer-subtitle">{{ store.description|raw }}</p>
					{% else %}
						<p class="footer-subtitle">AUTO PARTS & ACCESSORIES</p>
					{% endif %}
				</div>

				<div class="social-links-wrapper">
					<salla-social class="block mb-6"></salla-social>
				</div>

				<div class="newsletter">
					<p>ما بداخلنا: وصولات جديدة، عروض حصرية، أخبار الشاحنات والمزيد!</p>
					<div class="newsletter-form">
						<input type="email" placeholder="البريد الإلكتروني">
						<button type="submit"><i class="fas fa-arrow-left"></i></button>
					</div>
				</div>

		<div class="flex gap-4">
		  {# trust badges #}
		  <salla-trust-badges {% if theme.settings.get('footer_is_dark') %} dark {% endif %}></salla-trust-badges>
          {# vat #}
          {% if store.settings.tax.number %}
            <div class="flex rtl:space-x-reverse space-x-2 items-end">
              {% if store.settings.tax.certificate %}
                <a class="load-img-onclick" data-modal-id="modal-value-tax" href="#/" alt="{{ store.settings.tax.number }}">
                  <img width="40" height="50" src="{{'images/tax.png' | cdn(70,70)}}" loading="lazy" class="w-10 rounded-sm hover:opacity-80 transition-opacity" alt="value added tax">
                </a>
              {% endif %}
              <div>
                <p class="text-sm text-text-grey mb-1">{{ trans('common.elements.tax_number') }}</p>
                <b class="text-sm">{{ store.settings.tax.number }}</b>
              </div>
            </div>

            {% if store.settings.tax.certificate %}
              <salla-modal sub-title-first sub-title="{{ trans('common.elements.tax_number') }}" modal-title="{{ store.settings.tax.number }}" id="modal-value-tax">
                <div class="flex justify-center max-w-full">
                  <img class="w-full" loading="lazy" 
                  src="{{ store.settings.tax.certificate }}" 
                  alt="{{ store.settings.tax.number }}"/>
                </div>
              </salla-modal>
            {% endif %}
          {% endif %}
        </div>
        </div>

			<div>
				<h3>{{ trans('blocks.footer.pages_links') }}</h3>
				<salla-menu source="footer"></salla-menu>
			</div>

			<div>
				<salla-contacts></salla-contacts>

				<div class="lg:hidden contact-social">
					<salla-social></salla-social>
				</div>
			</div>

			<salla-apps-icons class="lg:col-span-2 rtl:lg:pr-20 ltr:lg:pl-20"></salla-apps-icons>

		</div>
	</div>

	<div class="md:flex items-center justify-between py-4 container text-center">
		<span class="text-sm copyright-text">{% hook copyright %}</span>
		<salla-payments></salla-payments>
	</div>
</footer>
